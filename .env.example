# 斗地主服务端环境变量配置
# 复制此文件为 .env 并根据需要修改
#
# 此文件仅包含 Docker 部署需要的配置
# 本地开发请直接使用 configs/config.yaml

# ===== 端口配置 =====
# WebSocket 服务端口
SERVER_PORT=1780

# ===== 版本控制 =====
# 要求的最低客户端版本（如 v1.2.0），留空表示不限制。
# 低于此版本的客户端启动时会被强制自动升级，用于发布不兼容变更时保证版本一致。
SERVER_MIN_CLIENT_VERSION=

# Redis 端口
REDIS_PORT=6379

# ===== Docker 专用配置 =====
# Redis 地址（Docker 使用服务名）
REDIS_ADDR=redis:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ===== AI 机器人 =====
# 是否启用 AI 机器人填充空座（true/false）
AI_ENABLED=true
# 是否使用 DouZero 神经网络引擎（关闭则使用内置规则启发式机器人）
AI_DOUZERO_ENABLED=true
# DouZero Python 服务地址（Docker 使用服务名）
AI_DOUZERO_URL=http://douzero:2021

# ===== 优雅关闭超时（分钟）=====
# 等待游戏结束的最长时间
# 建议：54张牌 * 30秒出牌时间 = 27分钟，设置为 30 分钟
# Docker 的 stop_grace_period 会使用此值
GAME_SHUTDOWN_TIMEOUT=30
